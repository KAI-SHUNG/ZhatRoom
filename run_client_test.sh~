#!/bin/bash

# 1. 编译程序 (确保程序没有语法错误)
echo "正在编译 Go 客户端..."
go build -o bin/client cmd/client/main.go
if [ $? -ne 0 ]; then
    echo "编译失败，请检查代码。"
    exit 1
fi

# 2. 设置参数变量
TOTAL_CLIENTS=10       # 想要启动的客户端总数
BASE_PARAM=1000        # 起始参数值

echo "开始启动 $TOTAL_CLIENTS 个客户端..."

for ((i=1; i<=TOTAL_CLIENTS; i++))
do
    # 计算当前的自增参数
    CURRENT_PARAM=$((BASE_PARAM + i))
    
    # 3. 运行程序并处理输出
    # 我们只将第一个进程的输出打印到屏幕，其余的全部重定向到黑洞 /dev/null
    if [ $i -eq 1 ]; then
        echo "正在监听第 1 个客户端 (参数: $CURRENT_PARAM) 的输出..."
        ./client --id=$CURRENT_PARAM --usr="user${CURRENT_PARAM}" & 
    else
        # 静默运行：丢弃标准输出 (1) 和标准错误 (2)
        ./client --id=$CURRENT_PARAM --usr="user${CURRENT_PARAM}" > /dev/null 2>&1 &
    fi
done

echo "所有客户端已在后台启动。"
# 等待所有后台进程结束，防止脚本直接退出
wait
